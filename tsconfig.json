{
    "extends": "../core/tsconfig.json",
    "compilerOptions": {
        "baseUrl": ".",
        "rootDir": "..",
        "paths": {
            "~/tinycld/drive/*": ["./tinycld/drive/*"],
            "@tinycld/core/*": ["../core/*"],
            "@tinycld/*": ["../core/packages/@tinycld/*"],
            "~/*": ["../core/*"]
        },
        "noEmit": true,
        "preserveSymlinks": false
    },
    "include": [
        "**/*.ts",
        "**/*.tsx",
        "../core/**/*.d.ts",
        "../core/expo-env.d.ts",
        "../core/.expo/types/**/*.ts"
    ],
    "exclude": ["node_modules", "server", "pb-migrations", "tests/**/*.spec.ts"]
}
