{
    "name": "@tinycld/drive",
    "version": "0.1.0",
    "private": true,
    "type": "module",
    "exports": {
        "./package.json": "./package.json",
        "./manifest": "./manifest.ts",
        "./types": "./types.ts",
        "./collections": "./collections.ts",
        "./screens/*": "./screens/*.tsx",
        "./sidebar": "./sidebar.tsx",
        "./provider": "./provider.tsx",
        "./seed": "./seed.ts",
        "./hooks/*": "./hooks/*.ts",
        "./components/*": "./components/*.tsx",
        "./public-screens/*": "./public-screens/*.tsx"
    },
    "scripts": {
        "lint": "biome check .",
        "lint:fix": "biome check --write .",
        "typecheck": "tsc --noEmit --skipLibCheck",
        "checks": "bun run lint && bun run typecheck"
    },
    "peerDependencies": {
        "react": ">=19",
        "react-native": ">=0.83",
        "expo-router": ">=55.0.0",
        "pbtsdb": ">=0.3",
        "@tanstack/react-db": ">=0.1",
        "@tanstack/db": ">=0.6"
    }
}
